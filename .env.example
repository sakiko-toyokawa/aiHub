DATABASE_URL=postgresql://user:pass@localhost:5432/ai_knowledge
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
DEFAULT_AI_PROVIDER=openai
# Platform Credentials
# 知乎: 从浏览器开发者工具复制 Cookie 中的 z_c0 值
ZHIHU_COOKIE=z_c0=xxx

# Bilibili: 从浏览器开发者工具复制 Cookie 中的 SESSDATA 值
BILIBILI_SESSDATA=xxx

# Twitter/X: 账号密码 (使用 twikit 库,无需 API Key)
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password
TWITTER_EMAIL=your_email@example.com
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=
CRAWL_SCHEDULE=0 */2 * * *
SUMMARIZE_SCHEDULE=0 */3 * * *
EMAIL_SCHEDULE=0 22 * * *
