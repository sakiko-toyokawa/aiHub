# AI Knowledge Hub - Environment Configuration
# Copy this file to backend/.env and fill in your configurations

# ========== AI Configuration (Fill at least one) ==========

# OpenAI API Key (Optional)
# Get it at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Claude API Key (Optional)
# Get it at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# DeepSeek API Key (Optional, recommended for China users)
# Get it at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# GLM API Key (Optional)
# Get it at: https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY=

# Kimi API Key (Optional)
# Get it at: https://platform.moonshot.cn/console/api-keys
KIMI_API_KEY=

# Kimi For Coding API Key (Claude Code proxy)
# Get it at: https://www.kimi.com/coding/docs/
KIMI_CODING_API_KEY=

# MiniMax API Key (Optional)
# Get it at: https://platform.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=

# Default AI Provider (openai/claude/deepseek/glm/kimi/kimi-coding/minimax)
DEFAULT_AI_PROVIDER=openai


# ========== Database Configuration ==========

# SQLite (Simplest, no database installation needed, suitable for personal use)
DATABASE_URL=sqlite:///./data/app.db

# PostgreSQL (Recommended for production, requires PostgreSQL installation)
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_knowledge


# ========== Crawler Configuration (Optional) ==========

# GitHub Token (Optional, for higher rate limit API access)
# Get it at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Bilibili SESSDATA (Optional, for content that requires login)
# How to get: Login to Bilibili, then find SESSDATA in DevTools -> Application -> Cookies
BILIBILI_SESSDATA=

# Zhihu Cookie (Optional, for content that requires login)
# How to get: Login to Zhihu, then copy key cookies from DevTools -> Application -> Cookies
# Format: z_c0=xxx; d_c0=xxx; _xsrf=xxx; __zse_ck=xxx
ZHIHU_COOKIE=

# Twitter/X Account (Optional, for crawling Twitter content)
TWITTER_USERNAME=
TWITTER_PASSWORD=
TWITTER_EMAIL=

# Twitter/X Cookie Login (Recommended, bypasses Cloudflare verification)
# How to get: Copy from DevTools -> Application -> Cookies after logging into Twitter
twitter_auth_token=
twitter_ct0=


# ========== Email Push Configuration (Optional) ==========
# Configure to automatically send AI knowledge digest to your email daily

# SMTP Server Configuration (QQ Mail example)
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your-email@qq.com
SMTP_PASSWORD=your-16-char-auth-code
EMAIL_TO=your-email@qq.com

# Scheduled Send Time (Cron expression)
# Default: Send at 22:00 every night
EMAIL_SCHEDULE=0 22 * * *

# Email Send Switch (true/false)
EMAIL_ENABLED=false


# ========== Scheduler Configuration ==========

# Crawler Schedule (Default: Every 2 hours)
CRAWL_SCHEDULE=0 */2 * * *

# Summary Generation Schedule (Default: Every 3 hours)
SUMMARIZE_SCHEDULE=0 */3 * * *


# ========== Other Configuration ==========

# Log Level (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# Timezone
TIMEZONE=Asia/Shanghai
